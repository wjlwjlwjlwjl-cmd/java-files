<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.wjl.mybatis.mapper.UserInfoMapperXML">
    <select id="selectAll" resultType="com.wjl.mybatis.entity.UserInfo">
        select * from user_info;
    </select>

    <insert id="insertOne" useGeneratedKeys="true" keyColumn="id">
        insert into user_info(user_name, user_age) values(#{userName}, #{userAge});
    </insert>

    <update id="updateAge">
        update user_info set user_age=#{userAge} where user_name=#{userName};
    </update>

    <delete id="deleteByName">
        delete from user_info where user_name=#{userName};
    </delete>
</mapper>